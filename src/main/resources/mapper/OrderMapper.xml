<!--
	мӣҗлһҳлҠ” orderмҷҖ productк°Җ 1:Nмқҳ кҙҖкі„к°Җ лҗҳм–ҙм•ј н•ңлӢӨ. 
	л°”лЎң orderмҷҖ productмқҳ кҙҖкі„к№Ң м•„лӢҲлқј,
	orderdetailмқҖ productлҘј к°җмӢёкі  мһҲлҠ” кІғкіј л№„мҠ·н•ҳлӢӨ.  
	к·ёлһҳм„ң orderкіј orderdetailмқҙ 1:NкҙҖкі„к°Җ лҗҳм–ҙм•јн•ңлӢӨ.
	-->

<!-- 1. order (1) : order_detail(N) -->
<!-- 2. order_detail (1) : product(1) , order_detailмқҖ prodcutлҘј к°җмӢёкі  мһҲлҠ” кІғкіј л№„мҠ·н•ҳлӢӨ.-->
<!-- 3. product(1) : pruduct_img(N)  -->
	
	<resultMap id="OrderDetail" type="Orderdetail">
		<result column="od_id" property="id" />
		<result column="od_product" property="product" />
		<result column="od_price" property="price" />
		<result column="p_id" property="p_id" />
	</resultMap>
	
	<resultMap id="Order" type="Order">
		<result column="o_id" property="id" />
		<result column="o_total_price" property="total_price" />
		<result column="o_state" property="state" />
		<collection property="orderdetail" resultMap="OrderDetail" />
	</resultMap>


	<select id="readOrderDetails" parameterType="Order" resultMap="Order">
		SELECT  		tb.od_id,
						tb.od_product,
						tb.od_price,
						tb.p_id,
						tb.o_id,
						ta.o_state,
						ta.o_total_price,
						ta.o_id

		FROM orders ta
		
		LEFT JOIN order_detail tb ON (ta.o_id = tb.o_id)

		
		WHERE ta.o_id = #{id}
		
		
		<!-- 
		SELECT  		user.user_name as name, 			
						user.user_address as address, 
						user.user_phone as phone,
		    			product.p_name as product, 
		    			product.p_price as price, 
		    			product.p_id as code,
			 			product_img.pi_image as image,
			 			order_detail.od_count as count
	
		FROM order_detail
		
		LEFT JOIN orders ON (order_detail.o_id = orders.o_id)
		LEFT JOIN user ON (orders.user_id = user.user_id)
		LEFT JOIN product ON(order_detail.p_id = product.p_id)
		LEFT JOIN product_img ON(product.p_id = product_img.p_id)
		
		WHERE order_detail.o_id = #{id}
		 -->
	</select>

</mapper>